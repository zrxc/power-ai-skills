{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://power-ai.local/schemas/team-policy.schema.json",
  "title": "Team Policy",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "allowedTools",
    "defaultTools",
    "requiredSkills",
    "wrapperPolicies",
    "projectProfiles",
    "releasePolicies"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "description": {
      "type": "string"
    },
    "allowedTools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/toolName"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "defaultTools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/toolName"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "requiredSkills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillPath"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "captureSafetyPolicy": {
      "$ref": "#/$defs/captureSafetyPolicy"
    },
    "wrapperPolicies": {
      "type": "object",
      "required": ["rolloutStages"],
      "properties": {
        "rolloutStages": {
          "type": "object",
          "additionalProperties": {
            "enum": ["general", "pilot", "compatible-only", "disabled"]
          }
        }
      },
      "additionalProperties": false
    },
    "projectProfiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "displayName", "defaultPreset", "allowedTools", "requiredSkills"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "displayName": {
            "type": "string"
          },
          "defaultPreset": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "allowedTools": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/toolName"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "requiredSkills": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/skillPath"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "releasePolicies": {
      "type": "object",
      "required": ["requiredReports", "requiredChecks", "enforceConsumerMatrix", "enforceReleaseGates"],
      "properties": {
        "requiredReports": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "requiredChecks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "enforceConsumerMatrix": {
          "type": "boolean"
        },
        "enforceReleaseGates": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "toolName": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "skillPath": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(?:/[a-z0-9-]+)+$"
    },
    "captureSafetyPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "redaction": {
          "type": "object",
          "properties": {
            "redactEmails": { "type": "boolean" },
            "redactBearerTokens": { "type": "boolean" },
            "redactKnownSecrets": { "type": "boolean" },
            "redactSecretAssignments": { "type": "boolean" },
            "redactAbsolutePaths": { "type": "boolean" },
            "preserveProjectRelativePaths": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "admission": {
          "type": "object",
          "properties": {
            "allowedSceneTypes": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "blockedSceneTypes": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "reviewSceneTypes": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "blockedIntentKeywords": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "reviewIntentKeywords": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "blockedGeneratedFilePatterns": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "reviewGeneratedFilePatterns": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "retention": {
          "type": "object",
          "properties": {
            "autoArchiveDays": {
              "type": "integer",
              "minimum": 0
            },
            "autoPruneDays": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
